# Sanity — `npx sanity init --env .env.local` writes the first two for you.
# Until they are set, the site renders the placeholder roll in src/data/roll.ts
# and /studio shows setup instructions instead of the editor.
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production

# Absolute origin for share cards. Without it they resolve to localhost.
NEXT_PUBLIC_SITE_URL=

# Viewer token for draft previews in the Studio's Presentation tab.
# Create one with: npx sanity tokens add "live preview" --role viewer
# Without it the site still works — you just lose draft-mode preview.
SANITY_API_READ_TOKEN=
